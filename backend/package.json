{
  "name": "sirkasir-backend",
  "version": "0.8.0",
  "private": true,
  "description": "Sirkasir POS backend - Node.js REST API dengan PostgreSQL (tanpa Prisma).",
  "scripts": {
    "migrate": "node src/db/migrate.js",
    "seed": "node src/seed.js",
    "seed:blank": "node src/seed.js --blank",
    "setup": "node src/db/migrate.js && node src/seed.js",
    "setup:blank": "node src/db/migrate.js && node src/seed.js --blank",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "^8.13.1"
  }
}
