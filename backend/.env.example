# Koneksi PostgreSQL. Pilih salah satu cara:
# 1) Satu baris connection string (paling gampang):
#
#   >>> WAJIB GANTI "postgres" kedua (setelah tanda ":") dengan PASSWORD
#       user postgres kamu. Format: postgresql://USER:PASSWORD@HOST:PORT/NAMA_DB
#       Kalau tidak diganti dan password tidak cocok, koneksi akan gagal
#       dengan pesan: password authentication failed.
#
DATABASE_URL=postgresql://postgres:GANTI_PASSWORD_ANDA@localhost:5432/sirkasir

# 2) Atau isi per bagian (hanya dipakai kalau DATABASE_URL kosong):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=sirkasir

# Set true kalau server DB butuh SSL (mis. Neon, Supabase, Railway):
# PGSSL=true

# Rahasia untuk menandatangani token login (WAJIB ganti di produksi dengan
# string acak panjang, mis. hasil: openssl rand -hex 32):
JWT_SECRET=sirkasir-dev-secret-change-me

# Port API:
PORT=4000
